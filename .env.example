# +----------------------------------------------------------------------
# | @project   BenXinAdmin · C 端环境变量示例
# | 复制为 .env.development / .env.production 后按环境填写（.env* 不入库）
# +----------------------------------------------------------------------

# 后端接口 baseURL（走 /api 前缀，业务码 code===0 判成功）
# 本地后端：daxing 用 `php think run -p 8801` 起服务
VITE_API_BASE_URL=http://127.0.0.1:8801/api

# C 端报文加密（AES-256-CBC）开关，默认关；按任务书指示再置 true
VITE_ENABLE_ENCRYPT=false
